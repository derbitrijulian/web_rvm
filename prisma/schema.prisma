generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String              @id @default(uuid())
  email       String              @unique
  createdAt   DateTime            @default(now())
  nama        String?
  password    String?
  phoneNumber String?             @map("phone_number")
  updatedAt   DateTime            @updatedAt
  bottleCount UserBottleCount?
  redemptions VoucherRedemption[]

  // Google OAuth fields
  googleId     String? @unique
  isGoogleAuth Boolean @default(false)

  // Password Reset fields
  resetPasswordToken       String?
  resetPasswordTokenExpiry DateTime?
}

model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  nama      String
  password  String
  role      AdminRole @default(OPERATOR)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?

  auditLogs AuditLog[]

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  CONTENT_MANAGER
}

model UserBottleCount {
  id              String   @id @default(uuid())
  userId          String   @unique
  totalBottles    Int      @default(0)
  redeemableCount Int      @default(0)
  lifetimeCount   Int      @default(0)
  points          Int      @default(0)
  lifetimePoints  Int      @default(0)
  lastUpdated     DateTime @default(now()) @updatedAt

  bottleCounts       BottleCount[]
  bottleTransactions BottleTransaction[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_bottle_counts")
}

model BottleTransaction {
  id                String   @id @default(uuid())
  userBottleCountId String
  deviceId          String?
  locationId        Int?
  transactionType   String
  bottleCount       Int
  pointsEarned      Int      @default(0)
  timestamp         DateTime @default(now())

  userBottleCount UserBottleCount    @relation(fields: [userBottleCountId], references: [id], onDelete: Cascade)
  device          ArduinoConnection? @relation(fields: [deviceId], references: [deviceId], onDelete: SetNull)
  location        RvmLocation?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  bottleCounts    BottleCount[]

  @@map("bottle_transactions")
}

model ArduinoConnection {
  id         Int      @id @default(autoincrement())
  deviceId   String   @unique
  locationId Int?
  ipAddress  String?
  status     String
  lastPing   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location     RvmLocation?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  transactions BottleTransaction[]
  bottleCounts BottleCount[]

  @@map("arduino_connections")
}

model RvmLocation {
  id               Int      @id @default(autoincrement())
  name             String
  address          String?
  position         Json
  capacity         Int      @default(100)
  currentStock     Int      @default(0)
  capacityStatus   String   @default("AVAILABLE")
  operationalHours String   @default("08:00-22:00")
  contactNumber    String?
  status           String   @default("ACTIVE")
  image            String?
  images           Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  arduinoConnections ArduinoConnection[]
  transactions       BottleTransaction[]

  @@map("rvm_locations")
}

enum BottleTransactionType {
  DEPOSIT
  REDEEM
  ADJUSTMENT
}

model BottleCount {
  id                  Int      @id @default(autoincrement())
  deviceId            String
  count               Int      @default(1)
  distance            Float?
  source              String   @default("arduino")
  timestamp           DateTime @default(now())
  userBottleCountId   String?
  bottleTransactionId String?

  userBottleCount UserBottleCount?   @relation(fields: [userBottleCountId], references: [id], onDelete: Cascade)
  device          ArduinoConnection  @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  transaction     BottleTransaction? @relation(fields: [bottleTransactionId], references: [id], onDelete: SetNull)

  @@map("bottle_counts")
}

// ===== ADMIN AUDIT MODELS =====

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  details    Json?
  ipAddress  String?
  timestamp  DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model News {
  id          String    @id @default(uuid())
  title       String
  content     String    @db.Text
  imageUrl    String?
  category    String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("news")
}

model Voucher {
  id         String    @id @default(uuid())
  code       String    @unique
  partner    String
  value      Int
  pointCost  Int
  stock      Int       @default(0)
  isActive   Boolean   @default(true)
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  redemptions VoucherRedemption[]

  @@map("vouchers")
}

model VoucherRedemption {
  id         String    @id @default(uuid())
  voucherId  String
  userId     String
  status     String
  redeemedAt DateTime  @default(now())
  usedAt     DateTime?

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voucher_redemptions")
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}
