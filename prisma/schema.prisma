generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String           @id @default(uuid())
  email       String           @unique
  createdAt   DateTime         @default(now())
  nama        String
  password    String
  phoneNumber String           @map("phone_number")
  updatedAt   DateTime         @updatedAt
  
  // Relasi one-to-one dengan UserBottleCount
  bottleCount UserBottleCount?
}

model UserBottleCount {
  id              String   @id @default(uuid())
  userId          String   @unique
  totalBottles    Int      @default(0)
  redeemableCount Int      @default(0)
  lifetimeCount   Int      @default(0)
  lastUpdated     DateTime @default(now()) @updatedAt
  
  // Relasi dengan User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_bottle_counts")
}

model BottleTransaction {
  id            String              @id @default(uuid())
  userId        String
  rvmLocationId Int?
  type          BottleTransactionType
  amount        Int
  description   String?
  createdAt     DateTime            @default(now())
  
  // Relasi dengan User (tanpa foreign key constraint untuk fleksibilitas)
  @@map("bottle_transactions")
}

enum BottleTransactionType {
  DEPOSIT   // Menambah bottle (dari RVM)
  REDEEM    // Menukar bottle dengan reward
  ADJUSTMENT // Penyesuaian manual
}

model RvmLocation {
  id             Int      @id @default(autoincrement())
  name           String
  position       Json
  capacity       Int
  capacityStatus String
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
}
